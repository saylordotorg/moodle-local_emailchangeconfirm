<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/emailchangeconfirm/db" VERSION="20260612" COMMENT="Database schema for local_emailchangeconfirm"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_emailchangeconfirm_requests" COMMENT="Pending email change verification requests">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK to user.id"/>
        <FIELD NAME="oldemail" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false" COMMENT="Email at time of request"/>
        <FIELD NAME="newemail" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false" COMMENT="Requested new email"/>
        <FIELD NAME="tokenhash" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false" COMMENT="SHA-256 hash of the raw token"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending" SEQUENCE="false" COMMENT="pending, verified, cancelled, expired"/>
        <FIELD NAME="attemptsleft" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="3" SEQUENCE="false" COMMENT="Remaining validation attempts"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timeexpires" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timeverified" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="ix_tokenhash" UNIQUE="false" FIELDS="tokenhash"/>
        <INDEX NAME="ix_userid_status" UNIQUE="false" FIELDS="userid, status"/>
        <INDEX NAME="ix_timeexpires_status" UNIQUE="false" FIELDS="timeexpires, status"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
