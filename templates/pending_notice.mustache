{{!
    @template local_emailchangeconfirm/pending_notice

    Displays a pending email change notice with a cancellation link.

    Context variables required for this template:
    * message - The localised pending message.
    * cancelurl - The cancellation URL.
    * cancellabel - The localised cancellation link label.

    Example context (json):
    {
        "message": "You have a pending email change to new@example.com.",
        "cancelurl": "https://example.com/local/emailchangeconfirm/verify.php?action=cancel&sesskey=abc",
        "cancellabel": "Cancel email change request"
    }
}}
<div class="alert alert-info local-emailchangeconfirm-pending" role="alert">
    <p>{{message}}</p>
    <a class="btn btn-secondary btn-sm" href="{{cancelurl}}">{{cancellabel}}</a>
</div>
